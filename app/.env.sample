PUBLIC_API_BASE_URL=http://localhost:8080

# Firebase web app config — all values are PUBLIC by design (they ship to the
# browser). Read them from the Firebase console:
#   Project settings → General → Your apps → Web app → SDK setup and configuration → Config.
# All 4 below are required; AUTH_DOMAIN and STORAGE_BUCKET are optional and
# default to <projectId>.firebaseapp.com / <projectId>.firebasestorage.app.

PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_PROJECT_ID=copro-manager
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# Optional — only set if your project doesn't use the defaults above.
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_STORAGE_BUCKET=
