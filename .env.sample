# Local-dev shell environment for the API.
# Copy this to ./.env at the repo root and fill in.
#
# Functional configuration (project, bucket, bypass key, admin api key…) is
# read from conf/*.yml — NOT from this file. Override per-machine values by
# creating api/conf/local.yml and pointing CONFIG_FILE at the layered list.

# Layered config files, separated by `:` (PathListSeparator). The right-most
# file wins on conflict. `api/conf/local.yml` is gitignored.
CONFIG_FILE=conf/main.yml:conf/local.yml

# Path to the Google service-account JSON for local development. The Firebase
# Admin SDK and Firestore client auto-detect this env var. Never commit the
# JSON itself — `creds/` is gitignored.
#
# This default is relative to the REPO ROOT. The `scripts/dev` helper always
# `cd`s to the repo root before launching, so this works out of the box. If
# you launch `go run ./bin/app` directly from `api/`, replace with an absolute
# path (e.g. /Users/you/perso/copro-manager/creds/dev.json).
GOOGLE_APPLICATION_CREDENTIALS=creds/dev.json

# Optional emulator hosts — when set, the Firebase Admin SDK and Firestore
# client auto-route to the local emulator instead of GCP.
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIRESTORE_EMULATOR_HOST=localhost:8081
